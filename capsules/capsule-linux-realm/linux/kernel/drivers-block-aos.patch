 obj-$(CONFIG_BLK_DEV_UBLK)			+= ublk_drv.o
 obj-$(CONFIG_BLK_DEV_ZONED_LOOP) += zloop.o
+obj-$(CONFIG_BLK_DEV_AOS_SYSTEM) += aos_system.o
 
 swim_mod-y	:= swim.o swim_asm.o
