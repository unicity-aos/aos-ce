diff --git a/drivers/block/Kconfig b/drivers/block/Kconfig
index 79c8be4de149..f5e03e6646f8 100644
--- a/drivers/block/Kconfig
+++ b/drivers/block/Kconfig
@@ -375,4 +375,13 @@ config BLK_DEV_ZONED_LOOP
 
 	  If unsure, say N.
 
+config BLK_DEV_AOS_SYSTEM
+	bool "AOS Realm immutable system device"
+	depends on RISCV && RISCV_SBI
+	help
+	  Exposes one read-only block device backed by a hash-pinned immutable
+	  asset attached to the signed AOS Linux vCPU worker. Reads cross the
+	  private synchronous SBI boundary in bounded chunks. There is no
+	  writable command, DMA surface, host path, or guest-selected asset.
+
 endif # BLK_DEV
